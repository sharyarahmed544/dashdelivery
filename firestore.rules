rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is an Admin
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'ADMIN';
    }

    // Public Collections (Read-only for public, Write for Admin)
    match /contentBlocks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /depotLocations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Submission Collections (Public Create, Admin Read/Write)
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, write: if isAdmin();
      
      // Tracking events subcollection
      match /tracking_events/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    match /contacts/{contactId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }
  }
}
